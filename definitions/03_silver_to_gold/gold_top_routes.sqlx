config {
  type: "view",
  schema: "Dataset_Academy2026_Molinaro"
}

select
  train_name,
  departure_city,
  arrival_city,
  count(*) as num_departures,
  sum(passengers) as total_passengers,
  round(avg(fill_ratio)*100, 2) as avg_fill_percentage
from ${ref("silver_departures")}
group by train_name, departure_city, arrival_city
order by total_passengers desc